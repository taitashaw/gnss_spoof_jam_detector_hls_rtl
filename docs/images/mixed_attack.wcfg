<?xml version="1.0" encoding="UTF-8"?>
<!-- Vivado XSim waveform configuration for the gnss_top mixed_attack run.
     Open with the regenerated mixed_attack.wdb (see docs/images/README.md) to
     reproduce the rendered docs/images/waveform_mixed_attack.png view.
     Author: John Bagshaw  License: MIT (c) 2026 John Bagshaw -->
<wave_config>
  <wave_state/>
  <db_ref_list>
    <db_ref path="mixed_attack.wdb" id="1"/>
  </db_ref_list>
  <WVObjectSize size="9"/>
  <wvobject type="logic" fp_name="/tb_gnss_top/s_tvalid">
    <obj_property name="ElementShortName">s_axis tvalid</obj_property></wvobject>
  <wvobject type="logic" fp_name="/tb_gnss_top/s_tready">
    <obj_property name="ElementShortName">s_axis tready</obj_property></wvobject>
  <wvobject type="logic" fp_name="/tb_gnss_top/s_tlast">
    <obj_property name="ElementShortName">s_axis tlast</obj_property></wvobject>
  <wvobject type="logic" fp_name="/tb_gnss_top/dut/tap_tvalid">
    <obj_property name="ElementShortName">tapped tvalid</obj_property></wvobject>
  <wvobject type="logic" fp_name="/tb_gnss_top/dut/tap_tready">
    <obj_property name="ElementShortName">tapped tready</obj_property></wvobject>
  <wvobject type="logic" fp_name="/tb_gnss_top/m_tvalid">
    <obj_property name="ElementShortName">metrics tvalid</obj_property></wvobject>
  <wvobject type="logic" fp_name="/tb_gnss_top/m_tready">
    <obj_property name="ElementShortName">metrics tready</obj_property></wvobject>
  <wvobject type="logic" fp_name="/tb_gnss_top/m_tlast">
    <obj_property name="ElementShortName">metrics tlast</obj_property></wvobject>
  <wvobject type="array" fp_name="/tb_gnss_top/m_tdata">
    <obj_property name="ElementShortName">metrics tdata</obj_property>
    <obj_property name="Radix">HEXRADIX</obj_property></wvobject>
</wave_config>
